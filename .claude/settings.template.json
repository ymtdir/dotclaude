{
  "permissions": {
    "allow": ["WebFetch(*)", "WebSearch(*)", "Read(*)", "Edit(*)", "Write(*)"],
    "deny": ["Read(./.env)", "Read(./.env.*)"],
    "ask": [
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git revert:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run format"
          }
        ]
      }
    ]
  }
}
